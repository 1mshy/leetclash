# Copy to .env for local dev (docker-compose reads this)
# Postgres is published on 5433, not the default 5432: a host-installed
# postgres (e.g. Homebrew postgres@17) grabs localhost:5432 first.
DATABASE_URL=postgres://leetclash:leetclash@localhost:5433/leetclash
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=leetclash
S3_SECRET_KEY=leetclash-secret
S3_BUCKET_TESTDATA=testdata
S3_BUCKET_SUBMISSIONS=submissions

# Judge backend (PLAN §4.1): judge0 = MVP quartet (works on macOS dev),
# isolate = Phase 3 custom workers (compose profile "judge-v2", Linux only).
JUDGE_BACKEND=judge0
# Ceiling on one exec batch round-trip to the isolate workers (ms).
JUDGE_EXEC_TIMEOUT_MS=300000

# Judge0 (MVP judge)
JUDGE0_URL=http://localhost:2358
# Apple Silicon dev only: the amd64 Judge0 image runs under Rosetta, which
# needs ≥512 MB of address space — set the floor or every run dies with a
# "rosetta error". Leave 0 in production so problem limits are enforced.
JUDGE0_MEMORY_FLOOR_KB=524288

# Observability (Phase 3): worker Prometheus port (api serves /metrics itself)
WORKER_METRICS_PORT=4100

# Auth
AUTH_SECRET=dev-secret-change-me
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Services
API_PORT=4000
REALTIME_PORT=4001
WEB_URL=http://localhost:3000
