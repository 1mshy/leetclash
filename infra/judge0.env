# Judge0 1.13.1 configuration (server + workers).
# DEV DEFAULTS ONLY — all passwords/secrets below MUST be changed in prod.

# Judge0's own Redis (queue) — the judge0-redis service on the `judge` network.
# A password is REQUIRED: Judge0 always sends AUTH, and an empty value makes
# every submission 500 with Redis::CommandError.
REDIS_HOST=judge0-redis
REDIS_PORT=6379
REDIS_PASSWORD=judge0-dev-password

# Judge0's own Postgres — the judge0-db service on the `judge` network
POSTGRES_HOST=judge0-db
POSTGRES_PORT=5432
POSTGRES_DB=judge0
POSTGRES_USER=judge0
POSTGRES_PASSWORD=judge0-dev-password

# Rails app env
RAILS_ENV=production
RAILS_MAX_THREADS=8
# CHANGE IN PROD: generate with `openssl rand -hex 32`
SECRET_KEY_BASE=dev-only-secret-key-base-change-me-in-prod

# Worker tuning
COUNT_OF_WORKERS=2
INTERVAL=0.1

# Submission defaults / caps (sane dev values)
ENABLE_WAIT_RESULT=true

# cgroup v2 workaround (Docker Desktop / modern kernels): Judge0 1.13.1's
# isolate only speaks cgroup v1, and its default whole-group limits invoke
# `isolate --cg`, which fails ("No such file or directory … /box"). Per-process
# rlimits skip --cg entirely. Dev-only tradeoff: a multi-process submission's
# memory is capped per process, not collectively. The Phase 3 custom judge
# (isolate 2.x, cgroup v2 native) removes this.
ENABLE_PER_PROCESS_AND_THREAD_TIME_LIMIT=true
ENABLE_PER_PROCESS_AND_THREAD_MEMORY_LIMIT=true
MAX_QUEUE_SIZE=100
CPU_TIME_LIMIT=5
MAX_CPU_TIME_LIMIT=15
WALL_TIME_LIMIT=10
MAX_WALL_TIME_LIMIT=30
MEMORY_LIMIT=512000
MAX_MEMORY_LIMIT=1024000
MAX_PROCESSES_AND_OR_THREADS=64
ENABLE_NETWORK=false
