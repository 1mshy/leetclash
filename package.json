    "test": "turbo run test",
    "problems:validate": "pnpm --filter @leetclash/problems validate"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "^5.11.1"
    }
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
